<?php

/**
 * @file
 * mlp_members.module — Member portal for Meadow Lane Park.
 */

use Drupal\Core\Url;

/**
 * Implements hook_theme().
 */
function mlp_members_theme(): array {
  return [
    'mlp_member_portal' => [
      'variables' => [
        'featured'      => NULL,
        'announcements' => [],
        'events'        => [],
        'board_email'   => '',
        'board_phone'   => '',
      ],
    ],
    'mlp_member_documents' => [
      'variables' => [
        'sections'      => [],
        'drive_enabled' => FALSE,
      ],
    ],
    'mlp_member_access_denied' => [
      'variables' => [],
    ],
    'mlp_events' => [
      'variables' => [
        'events'  => [],
        'can_add' => FALSE,
      ],
    ],
    'mlp_history' => [
      'variables' => [
        'photos_url' => '',
        'join_url'   => '',
        'documents'  => [],
        'can_manage' => FALSE,
      ],
    ],
    'mlp_history_submit' => [
      'variables' => [
        'form' => NULL,
      ],
    ],
    // Note: can_edit and can_delete are per-event flags inside the events array.
    'mlp_announcements' => [
      'variables' => [
        'items'       => [],
        'categories'  => [],
        'active_tid'  => 0,
        'page'        => 0,
        'total_pages' => 1,
        'total'       => 0,
        'can_add'     => FALSE,
      ],
    ],
    'mlp_announcement_detail' => [
      'variables' => [
        'title'       => '',
        'body'        => '',
        'created'     => NULL,
        'sticky'      => FALSE,
        'featured'    => FALSE,
        'categories'  => [],
        'can_edit'    => FALSE,
        'can_delete'  => FALSE,
        'node_id'     => NULL,
        'attachments' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * Adds portal navigation tabs on member pages.
 */
function mlp_members_local_tasks_alter(array &$data, ?string $route_name): void {
  // Guard against null route_name during router rebuild.
  if (empty($route_name)) {
    return;
  }
  if (!in_array($route_name, ['mlp_members.portal', 'mlp_members.documents'])) {
    return;
  }
  $data['tabs'][0]['mlp_members.portal'] = [
    '#theme'  => 'menu_local_task',
    '#link'   => [
      'title'             => t('Dashboard'),
      'url'               => Url::fromRoute('mlp_members.portal'),
      'localized_options' => [],
    ],
    '#active' => $route_name === 'mlp_members.portal',
    '#weight' => 0,
  ];
  $data['tabs'][0]['mlp_members.documents'] = [
    '#theme'  => 'menu_local_task',
    '#link'   => [
      'title'             => t('Documents'),
      'url'               => Url::fromRoute('mlp_members.documents'),
      'localized_options' => [],
    ],
    '#active' => $route_name === 'mlp_members.documents',
    '#weight' => 10,
  ];
}

/**
 * Implements hook_user_login().
 * After regular login, redirect to member portal if no destination set.
 * One-time login resets are handled by Drupal core — we don't interfere.
 */
function mlp_members_user_login($account): void {
  $request     = \Drupal::request();
  $destination = $request->query->get('destination');

  if ($destination) {
    return; // Honour existing destination.
  }

  // Don't interfere with password reset flow — Drupal handles the redirect
  // to the change password form with the current-password bypass in place.
  $route = \Drupal::routeMatch()->getRouteName();
  if (in_array($route, ['user.reset.login', 'user.reset', 'user.reset.form'])) {
    return;
  }

  // Regular login — go to member portal.
  $request->query->set('destination', '/member');
}


/**
 * Implements hook_node_insert().
 * Redirect to a useful page after saving an announcement or event.
 */
function mlp_members_node_insert(\Drupal\node\NodeInterface $node): void {
  // Send newsletter BEFORE redirect — redirect calls exit() which would abort sending.
  mlp_members_node_insert_newsletter($node);
  mlp_members_node_redirect($node);
}

/**
 * Implements hook_node_update().
 */
function mlp_members_node_update(\Drupal\node\NodeInterface $node): void {
  // Send newsletter BEFORE redirect.
  mlp_members_node_insert_newsletter($node);
  mlp_members_node_redirect($node);
}


/**
 * Implements hook_node_delete().
 */
function mlp_members_node_delete(\Drupal\node\NodeInterface $node): void {
  // For delete, we cannot use node->id() as destination since it will be gone.
  // Redirect based on type only.
  $destinations = [
    'announcement'    => '/announcements',
    'event'           => '/events',
    'history_document' => '/history',
  ];
  $type = $node->bundle();
  if (isset($destinations[$type])) {
    $response = new \Symfony\Component\HttpFoundation\RedirectResponse($destinations[$type]);
    $response->send();
    exit;
  }
}
/**
 * Redirect after saving member content types.
 */
function mlp_members_node_redirect(\Drupal\node\NodeInterface $node): void {
  $destinations = [
    'announcement'    => '/announcements/' . $node->id(),
    'event'           => '/events',
    'history_document' => '/history',
  ];
  if (isset($destinations[$node->bundle()])) {
    $response = new \Symfony\Component\HttpFoundation\RedirectResponse($destinations[$node->bundle()]);
    $response->send();
    exit;
  }
}

/**
 * Implements hook_user_insert().
 * Auto-subscribe new members to the announcements newsletter.
 */
function mlp_members_user_insert(\Drupal\user\UserInterface $account): void {
  if (!\Drupal::moduleHandler()->moduleExists('simplenews')) {
    return;
  }
  try {
    $newsletter_id = 'announcements';
    $newsletter = \Drupal::entityTypeManager()
      ->getStorage('simplenews_newsletter')
      ->load($newsletter_id);
    if (!$newsletter) {
      return;
    }
    \Drupal::service('simplenews.subscription_manager')
      ->subscribe($account->getEmail(), $newsletter_id, FALSE);
  }
  catch (\Exception $e) {
    \Drupal::logger('mlp_members')->error(
      'Failed to auto-subscribe user @email to newsletter: @message',
      ['@email' => $account->getEmail(), '@message' => $e->getMessage()]
    );
  }
}

/**
 * Implements hook_node_insert() — also triggers newsletter for announcements.
 * Note: this supplements the existing node_insert/redirect logic.
 */
function mlp_members_node_presave(\Drupal\node\NodeInterface $node): void {
  if ($node->bundle() !== 'announcement') {
    return;
  }
  if (!\Drupal::moduleHandler()->moduleExists('simplenews')) {
    return;
  }
  // Only send when transitioning from unpublished to published.
  $is_new       = $node->isNew();
  $was_published = !$is_new && !$node->original->isPublished();
  $now_published = $node->isPublished();

  if (!$now_published || (!$is_new && !$was_published)) {
    return;
  }

  // Mark the node so we send after save (we need the full entity saved first).
  $node->_mlp_send_newsletter = TRUE;
}

/**
 * Send newsletter after a new announcement is published.
 * Compatible with Simplenews 4.x spool-based API.
 */
function mlp_members_node_insert_newsletter(\Drupal\node\NodeInterface $node): void {
  if (empty($node->_mlp_send_newsletter)) {
    return;
  }
  if (!\Drupal::moduleHandler()->moduleExists('simplenews')) {
    return;
  }
  try {
    $newsletter = \Drupal::entityTypeManager()
      ->getStorage('simplenews_newsletter')
      ->load('announcements');
    if (!$newsletter) {
      \Drupal::logger('mlp_members')->warning(
        'Announcements newsletter not found — create it at Structure → Newsletters.'
      );
      return;
    }

    // Build the email body.
    $body = '';
    if ($node->hasField('field_announcement_body') && !$node->get('field_announcement_body')->isEmpty()) {
      $body = $node->get('field_announcement_body')->value;
    }
    $url  = \Drupal::request()->getSchemeAndHttpHost() . '/announcements/' . $node->id();
    // Build branded HTML email.
    $site_name = \Drupal::config('system.site')->get('name');
    $base_url = \Drupal::request()->getSchemeAndHttpHost();
    $attachment_names = [];
    if ($node->hasField('field_announcement_attachments') && !$node->get('field_announcement_attachments')->isEmpty()) {
      $file_storage = \Drupal::entityTypeManager()->getStorage('file');
      foreach ($node->get('field_announcement_attachments') as $item) {
        $file = $item->target_id ? $file_storage->load($item->target_id) : NULL;
        if ($file) {
          $attachment_names[] = [
            'name' => $item->description ?: $file->getFilename(),
            'url'  => \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri()),
          ];
        }
      }
    }
    $html = mlp_members_announcement_email_html($node->getTitle(), $body, $url, $site_name, $base_url);

    // Collect attachments.
    $attachments = [];
    if ($node->hasField('field_announcement_attachments') && !$node->get('field_announcement_attachments')->isEmpty()) {
      foreach ($node->get('field_announcement_attachments') as $item) {
        $file = $item->entity;
        if ($file) {
          $attachments[] = $file->getFileUri();
        }
      }
    }
    // Store HTML and attachments in state for hook_mailer_message_alter.
    \Drupal::state()->set('mlp_pending_html', $html);
    \Drupal::state()->set('mlp_pending_attachments', $attachments);

    // In Simplenews 4.x, send by creating a node with the simplenews_issue field
    // and using the spooler to dispatch it.
    $issue = \Drupal::entityTypeManager()->getStorage('node')->create([
      'type'             => 'simplenews_issue',
      'title'            => $node->getTitle(),
      'simplenews_issue' => [
        'target_id' => $newsletter->id(),
      ],
      'body' => [
        'value'   => $html,
        'summary' => '',
        'format'  => 'full_html',
      ],
      'status' => 1,
      'uid'    => 1,
    ]);
    $issue->save();

    \Drupal::logger('mlp_members')->notice(
      'Newsletter issue created: @id for announcement @nid',
      ['@id' => $issue->id(), '@nid' => $node->id()]
    );

    // Send immediately via the spooler (Simplenews 4.x API).
    \Drupal::service('simplenews.spool_storage')->addIssue($issue);
    \Drupal::service('simplenews.mailer')->sendSpool();
    \Drupal::service('simplenews.spool_storage')->clear();
    \Drupal::state()->delete('mlp_pending_attachments');

  }
  catch (\Exception $e) {
    \Drupal::logger('mlp_members')->error(
      'Failed to send announcement newsletter: @message',
      ['@message' => $e->getMessage()]
    );
  }
}


/**
 * Builds a branded HTML email for an announcement.
 */
function mlp_members_announcement_email_html(string $title, string $body, string $url, string $site_name, string $base_url = ''): string {
  $img_url = $base_url . '/themes/custom/meadow_lane/images/hero-aerial.jpg';

  $html  = '<!DOCTYPE html><html lang="en"><head>';
  $html .= '<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">';
  $html .= '<title>' . htmlspecialchars($title) . '</title></head>';
  $html .= '<body style="margin:0;padding:0;background-color:#F5F4EF;font-family:Georgia,serif;">';
  $html .= '<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F5F4EF;">';
  $html .= '<tr><td align="center" style="padding:40px 16px;">';
  $html .= '<table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;width:100%;">';

  // Header with aerial photo background.
  $html .= '<tr><td style="border-radius:12px 12px 0 0;overflow:hidden;padding:0;background-color:#1a2820;';
  $html .= 'background-image:url(\'' . $img_url . '\');background-size:cover;background-position:center;">';
  $html .= '<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">';
  $html .= '<tr><td style="padding:48px 40px;text-align:center;background-color:rgba(26,40,32,0.62);">';
  $html .= '<h1 style="margin:0;font-family:Georgia,serif;font-size:26px;font-weight:400;color:#ffffff;letter-spacing:0.04em;">' . htmlspecialchars($site_name) . '</h1>';
  $html .= '<p style="margin:8px 0 0;font-family:system-ui,-apple-system,sans-serif;font-size:12px;color:rgba(255,255,255,0.65);letter-spacing:0.06em;text-transform:uppercase;">Member Mail</p>';
  $html .= '</td></tr></table></td></tr>';

  // Body.
  $html .= '<tr><td style="background-color:#ffffff;padding:40px 40px 32px;border-left:1px solid #e5e7e6;border-right:1px solid #e5e7e6;">';
  $html .= '<p style="margin:0 0 20px;font-family:system-ui,-apple-system,sans-serif;font-size:14px;color:#6E9E92;font-style:italic;">Greetings, Neighbor! A new announcement has been posted to the announcement board:</p>';
  $html .= '<h2 style="margin:0 0 24px;font-family:Georgia,serif;font-size:26px;font-weight:400;color:#1a2820;line-height:1.3;">' . htmlspecialchars($title) . '</h2>';
  $html .= '<div style="font-family:system-ui,-apple-system,sans-serif;font-size:15px;line-height:1.7;color:#374640;">' . $body . '</div>';
  $html .= '</td></tr>';

  // CTA button.
  $html .= '<tr><td style="background-color:#ffffff;padding:0 40px 40px;border-left:1px solid #e5e7e6;border-right:1px solid #e5e7e6;">';
  $html .= '<table role="presentation" cellspacing="0" cellpadding="0" border="0"><tr>';
  $html .= '<td style="border-radius:8px;background-color:#4A7C6F;">';
  $html .= '<a href="' . $url . '" style="display:inline-block;padding:12px 28px;font-family:system-ui,-apple-system,sans-serif;font-size:14px;font-weight:500;color:#ffffff;text-decoration:none;border-radius:8px;">Read on the website &rarr;</a>';
  $html .= '</td></tr></table></td></tr>';

  // Footer.
  $html .= '<tr><td style="background-color:#F5F4EF;border:1px solid #e5e7e6;border-top:none;border-radius:0 0 12px 12px;padding:24px 40px;text-align:center;">';
  $html .= '<p style="margin:0 0 8px;font-family:system-ui,-apple-system,sans-serif;font-size:12px;color:#8a9a92;">' . htmlspecialchars($site_name) . ' &middot; Alexandria Bay, NY</p>';
  $html .= '<p style="margin:0;font-family:system-ui,-apple-system,sans-serif;font-size:11px;color:#aab8b2;">You are receiving this because you are a registered member of the community portal.<br>';
  $html .= 'To unsubscribe, <a href="' . $url . '" style="color:#4A7C6F;">manage your preferences</a>.</p>';
  $html .= '</td></tr>';
  $html .= '</table></td></tr></table></body></html>';

  return $html;
}

/**
 * Implements hook_mail_alter().
 * Sets branded HTML body on announcement newsletter emails.
 * This is the correct hook for Symfony Mailer 1.x which calls hook_mail_alter
 * via LegacyEmailBuilder.
 */
function mlp_members_mail_alter(array &$message): void {

  // Welcome email for new member accounts.
  if (isset($message['id']) && $message['id'] === 'user_register_admin_created') {
    $account = $message['params']['account'] ?? NULL;
    if ($account) {
      $html = mlp_members_welcome_email_html($account, $message['params']);
      $message['body'] = [\Drupal\Core\Render\Markup::create($html)];
    }
    return;
  }

  // Only act on simplenews emails.
  if (!isset($message['id']) || strpos($message['id'], 'simplenews') === FALSE) {
    return;
  }

  // Set branded HTML body.
  $html = \Drupal::state()->get('mlp_pending_html', '');
  if ($html) {
    // Wrap in Markup so formatBody() treats it as raw HTML (#markup)
    // rather than processed_text which would escape the HTML tags.
    $message['body'] = [\Drupal\Core\Render\Markup::create($html)];
    \Drupal::state()->delete('mlp_pending_html');
  }

  // Attach files directly to the email.
  $attachment_uris = \Drupal::state()->get('mlp_pending_attachments', []);
  if (!empty($attachment_uris)) {
    $file_system = \Drupal::service('file_system');
    $file_storage = \Drupal::entityTypeManager()->getStorage('file');
    if (!isset($message['params']['attachments'])) {
      $message['params']['attachments'] = [];
    }
    foreach ($attachment_uris as $uri) {
      $path = $file_system->realpath($uri);
      if ($path && file_exists($path)) {
        // Look up mime type and filename from the file entity.
        $files = $file_storage->loadByProperties(['uri' => $uri]);
        $file  = $files ? reset($files) : NULL;
        $message['params']['attachments'][] = [
          'filepath' => $path,
          'filename' => $file ? $file->getFilename() : basename($path),
          'filemime' => $file ? $file->getMimeType() : 'application/octet-stream',
        ];
      }
    }
    \Drupal::state()->delete('mlp_pending_attachments');
  }
}

/**
 * Implements hook_node_view().
 * Redirects direct node views to our custom portal pages.
 */
function mlp_members_node_view(array &$build, \Drupal\node\NodeInterface $node, \Drupal\Core\Entity\Display\EntityViewDisplayInterface $display, $view_mode): void {
  // Only redirect on full page view, not teasers or other view modes.
  if ($view_mode !== 'full') {
    return;
  }

  // Only redirect on actual page requests, not admin previews or form submissions.
  $route = \Drupal::routeMatch()->getRouteName();
  if ($route !== 'entity.node.canonical') {
    return;
  }

  $redirects = [
    'announcement'    => '/announcements/' . $node->id(),
    'event'           => '/events',
    'history_document' => '/history',
  ];

  $type = $node->bundle();
  if (isset($redirects[$type])) {
    $response = new \Symfony\Component\HttpFoundation\RedirectResponse($redirects[$type]);
    $response->send();
    exit;
  }
}

/**
 * Builds a branded HTML welcome email for new member accounts.
 */
function mlp_members_welcome_email_html(\Drupal\user\UserInterface $account, array $params): string {
  $site_name = \Drupal::config('system.site')->get('name');
  $base_url  = \Drupal::request()->getSchemeAndHttpHost();
  $img_url   = $base_url . '/themes/custom/meadow_lane/images/hero-aerial.jpg';
  $login_url = $base_url . '/user/login';
  $portal_url = $base_url . '/member';

  // Get the one-time login link from the message params if available,
  // otherwise generate one.
  $one_time_url = '';
  if (!empty($params['one_time_login_url'])) {
    $one_time_url = $params['one_time_login_url'];
  }
  else {
    $timestamp = \Drupal::time()->getRequestTime();
    $one_time_url = user_pass_reset_url($account) ?? $login_url;
  }

  $display_name = $account->getDisplayName();

  $html  = '<!DOCTYPE html><html lang="en"><head>';
  $html .= '<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">';
  $html .= '<title>Welcome to ' . htmlspecialchars($site_name) . '</title></head>';
  $html .= '<body style="margin:0;padding:0;background-color:#F5F4EF;font-family:Georgia,serif;">';
  $html .= '<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F5F4EF;">';
  $html .= '<tr><td align="center" style="padding:40px 16px;">';
  $html .= '<table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;width:100%;">';

  // Header with aerial photo.
  $html .= '<tr><td style="border-radius:12px 12px 0 0;overflow:hidden;padding:0;background-color:#1a2820;';
  $html .= 'background-image:url(\'' . $img_url . '\');background-size:cover;background-position:center;">';
  $html .= '<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">';
  $html .= '<tr><td style="padding:48px 40px;text-align:center;background-color:rgba(26,40,32,0.62);">';
  $html .= '<h1 style="margin:0;font-family:Georgia,serif;font-size:26px;font-weight:400;color:#ffffff;letter-spacing:0.04em;">' . htmlspecialchars($site_name) . '</h1>';
  $html .= '<p style="margin:8px 0 0;font-family:system-ui,-apple-system,sans-serif;font-size:12px;color:rgba(255,255,255,0.65);letter-spacing:0.06em;text-transform:uppercase;">Welcome to the Member Portal</p>';
  $html .= '</td></tr></table></td></tr>';

  // Body.
  $html .= '<tr><td style="background-color:#ffffff;padding:40px 40px 32px;border-left:1px solid #e5e7e6;border-right:1px solid #e5e7e6;">';
  $html .= '<p style="margin:0 0 20px;font-family:system-ui,-apple-system,sans-serif;font-size:14px;color:#6E9E92;font-style:italic;">Greetings, Neighbor!</p>';
  $html .= '<h2 style="margin:0 0 20px;font-family:Georgia,serif;font-size:26px;font-weight:400;color:#1a2820;line-height:1.3;">Your member account is ready.</h2>';
  $html .= '<p style="margin:0 0 24px;font-family:system-ui,-apple-system,sans-serif;font-size:15px;line-height:1.7;color:#374640;">';
  $html .= 'An account has been created for you on the ' . htmlspecialchars($site_name) . ' member portal. ';
  $html .= 'Use the button below to set your password and log in for the first time.</p>';

  // Set password CTA.
  $html .= '<table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px;">';
  $html .= '<tr><td style="border-radius:8px;background-color:#4A7C6F;">';
  $html .= '<a href="' . $one_time_url . '" style="display:inline-block;padding:14px 32px;font-family:system-ui,-apple-system,sans-serif;font-size:14px;font-weight:500;color:#ffffff;text-decoration:none;border-radius:8px;">Set your password &rarr;</a>';
  $html .= '</td></tr></table>';

  // Note about link expiry.
  $html .= '<p style="margin:0 0 32px;font-family:system-ui,-apple-system,sans-serif;font-size:12px;color:#8a9a92;line-height:1.6;">';
  $html .= 'This link expires in 24 hours. If it has expired, visit <a href="' . $base_url . '/user/password" style="color:#4A7C6F;">' . $base_url . '/user/password</a> to request a new one.</p>';

  // Divider.
  $html .= '<hr style="border:none;border-top:1px solid #e5e7e6;margin:0 0 32px;">';

  // Features overview.
  $html .= '<h3 style="margin:0 0 16px;font-family:Georgia,serif;font-size:18px;font-weight:400;color:#1a2820;">What\'s available in the member portal</h3>';

  $features = [
    ['📣', 'Announcements', 'Stay up to date with notices from the board and community.'],
    ['📅', 'Events', 'View the community calendar and upcoming events.'],
    ['📁', 'Documents', 'Access community documents, bylaws, and files.'],
    ['📸', 'Community History', 'Browse the photo album and submit historical documents.'],
  ];

  $html .= '<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">';
  foreach ($features as $feature) {
    $html .= '<tr><td style="padding:10px 0;border-bottom:1px solid #f0f0f0;vertical-align:top;">';
    $html .= '<table role="presentation" cellspacing="0" cellpadding="0" border="0"><tr>';
    $html .= '<td style="font-size:20px;padding-right:14px;vertical-align:top;line-height:1.4;">' . $feature[0] . '</td>';
    $html .= '<td><p style="margin:0;font-family:system-ui,-apple-system,sans-serif;font-size:14px;font-weight:600;color:#1a2820;">' . $feature[1] . '</p>';
    $html .= '<p style="margin:2px 0 0;font-family:system-ui,-apple-system,sans-serif;font-size:13px;color:#6b7c75;line-height:1.5;">' . $feature[2] . '</p></td>';
    $html .= '</tr></table></td></tr>';
  }
  $html .= '</table>';

  $html .= '</td></tr>';

  // Visit portal CTA.
  $html .= '<tr><td style="background-color:#EEF7F4;padding:24px 40px;border-left:1px solid #e5e7e6;border-right:1px solid #e5e7e6;text-align:center;">';
  $html .= '<p style="margin:0 0 12px;font-family:system-ui,-apple-system,sans-serif;font-size:13px;color:#4A7C6F;">Once your password is set, your portal is at:</p>';
  $html .= '<a href="' . $portal_url . '" style="font-family:system-ui,-apple-system,sans-serif;font-size:14px;font-weight:500;color:#1a2820;text-decoration:none;">' . $portal_url . '</a>';
  $html .= '</td></tr>';

  // Footer.
  $html .= '<tr><td style="background-color:#F5F4EF;border:1px solid #e5e7e6;border-top:none;border-radius:0 0 12px 12px;padding:24px 40px;text-align:center;">';
  $html .= '<p style="margin:0 0 8px;font-family:system-ui,-apple-system,sans-serif;font-size:12px;color:#8a9a92;">' . htmlspecialchars($site_name) . ' &middot; Alexandria Bay, NY</p>';
  $html .= '<p style="margin:0;font-family:system-ui,-apple-system,sans-serif;font-size:11px;color:#aab8b2;">This email was sent because an account was created for you on the community portal.</p>';
  $html .= '</td></tr>';

  $html .= '</table></td></tr></table></body></html>';

  return $html;
}

/**
 * Implements hook_form_user_form_alter().
 * After saving account/password, redirect to member portal.
 */
function mlp_members_form_user_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state): void {
  $form['actions']['submit']['#submit'][] = 'mlp_members_user_form_submit';
}

/**
 * Custom submit handler for user account form.
 */
function mlp_members_user_form_submit(array &$form, \Drupal\Core\Form\FormStateInterface $form_state): void {
  $form_state->setRedirect('mlp_members.portal');
}
