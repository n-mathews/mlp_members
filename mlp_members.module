<?php

/**
 * @file
 * mlp_members.module — Member portal for Meadow Lane Park.
 */

use Drupal\Core\Url;

/**
 * Implements hook_theme().
 */
function mlp_members_theme(): array {
  return [
    'mlp_member_portal' => [
      'variables' => [
        'featured'      => NULL,
        'announcements' => [],
        'events'        => [],
      ],
    ],
    'mlp_member_documents' => [
      'variables' => [
        'sections'      => [],
        'drive_enabled' => FALSE,
      ],
    ],
    'mlp_member_access_denied' => [
      'variables' => [],
    ],
    'mlp_events' => [
      'variables' => [
        'events'  => [],
        'can_add' => FALSE,
      ],
    ],
    'mlp_history' => [
      'variables' => [
        'photos_url' => '',
        'join_url'   => '',
        'documents'  => [],
        'can_manage' => FALSE,
      ],
    ],
    'mlp_history_submit' => [
      'variables' => [
        'form' => NULL,
      ],
    ],
    // Note: can_edit and can_delete are per-event flags inside the events array.
    'mlp_announcements' => [
      'variables' => [
        'items'       => [],
        'categories'  => [],
        'active_tid'  => 0,
        'page'        => 0,
        'total_pages' => 1,
        'total'       => 0,
        'can_add'     => FALSE,
      ],
    ],
    'mlp_announcement_detail' => [
      'variables' => [
        'title'      => '',
        'body'       => '',
        'created'    => NULL,
        'sticky'     => FALSE,
        'featured'   => FALSE,
        'categories' => [],
        'can_edit'   => FALSE,
        'can_delete' => FALSE,
        'node_id'    => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * Adds portal navigation tabs on member pages.
 */
function mlp_members_local_tasks_alter(array &$data, ?string $route_name): void {
  // Guard against null route_name during router rebuild.
  if (empty($route_name)) {
    return;
  }
  if (!in_array($route_name, ['mlp_members.portal', 'mlp_members.documents'])) {
    return;
  }
  $data['tabs'][0]['mlp_members.portal'] = [
    '#theme'  => 'menu_local_task',
    '#link'   => [
      'title'             => t('Dashboard'),
      'url'               => Url::fromRoute('mlp_members.portal'),
      'localized_options' => [],
    ],
    '#active' => $route_name === 'mlp_members.portal',
    '#weight' => 0,
  ];
  $data['tabs'][0]['mlp_members.documents'] = [
    '#theme'  => 'menu_local_task',
    '#link'   => [
      'title'             => t('Documents'),
      'url'               => Url::fromRoute('mlp_members.documents'),
      'localized_options' => [],
    ],
    '#active' => $route_name === 'mlp_members.documents',
    '#weight' => 10,
  ];
}

/**
 * Implements hook_user_login().
 * Redirect to /member after login if no other destination is set.
 */
function mlp_members_user_login($account): void {
  $destination = \Drupal::request()->query->get('destination');
  if (!$destination) {
    \Drupal::service('request_stack')->getCurrentRequest()->query->set('destination', '/member');
  }
}

/**
 * Implements hook_node_insert().
 * Redirect to a useful page after saving an announcement or event.
 */
function mlp_members_node_insert(\Drupal\node\NodeInterface $node): void {
  mlp_members_node_redirect($node);
  mlp_members_node_insert_newsletter($node);
}

/**
 * Implements hook_node_update().
 */
function mlp_members_node_update(\Drupal\node\NodeInterface $node): void {
  mlp_members_node_redirect($node);
}


/**
 * Implements hook_node_delete().
 */
function mlp_members_node_delete(\Drupal\node\NodeInterface $node): void {
  // For delete, we cannot use node->id() as destination since it will be gone.
  // Redirect based on type only.
  $destinations = [
    'announcement'    => '/announcements',
    'event'           => '/events',
    'history_document' => '/history',
  ];
  $type = $node->bundle();
  if (isset($destinations[$type])) {
    $response = new \Symfony\Component\HttpFoundation\RedirectResponse($destinations[$type]);
    $response->send();
    exit;
  }
}
/**
 * Redirect after saving member content types.
 */
function mlp_members_node_redirect(\Drupal\node\NodeInterface $node): void {
  $destinations = [
    'announcement'    => '/announcements/' . $node->id(),
    'event'           => '/events',
    'history_document' => '/history',
  ];
  if (isset($destinations[$node->bundle()])) {
    $response = new \Symfony\Component\HttpFoundation\RedirectResponse($destinations[$node->bundle()]);
    $response->send();
    exit;
  }
}

/**
 * Implements hook_user_insert().
 * Auto-subscribe new members to the announcements newsletter.
 */
function mlp_members_user_insert(\Drupal\user\UserInterface $account): void {
  if (!\Drupal::moduleHandler()->moduleExists('simplenews')) {
    return;
  }
  try {
    $newsletter_id = 'announcements';
    $newsletter = \Drupal::entityTypeManager()
      ->getStorage('simplenews_newsletter')
      ->load($newsletter_id);
    if (!$newsletter) {
      return;
    }
    $subscriber = \Drupal::service('simplenews.subscription_manager')
      ->subscribe($account->getEmail(), $newsletter_id, FALSE, 'mlp_auto');
  }
  catch (\Exception $e) {
    \Drupal::logger('mlp_members')->error(
      'Failed to auto-subscribe user @email to newsletter: @message',
      ['@email' => $account->getEmail(), '@message' => $e->getMessage()]
    );
  }
}

/**
 * Implements hook_node_insert() — also triggers newsletter for announcements.
 * Note: this supplements the existing node_insert/redirect logic.
 */
function mlp_members_node_presave(\Drupal\node\NodeInterface $node): void {
  if ($node->bundle() !== 'announcement') {
    return;
  }
  if (!\Drupal::moduleHandler()->moduleExists('simplenews')) {
    return;
  }
  // Only send when transitioning from unpublished to published.
  $is_new       = $node->isNew();
  $was_published = !$is_new && !$node->original->isPublished();
  $now_published = $node->isPublished();

  if (!$now_published || (!$is_new && !$was_published)) {
    return;
  }

  // Mark the node so we send after save (we need the full entity saved first).
  $node->_mlp_send_newsletter = TRUE;
}

/**
 * Send newsletter after a new announcement is published.
 */
function mlp_members_node_insert_newsletter(\Drupal\node\NodeInterface $node): void {
  if (empty($node->_mlp_send_newsletter)) {
    return;
  }
  if (!\Drupal::moduleHandler()->moduleExists('simplenews')) {
    return;
  }
  try {
    $newsletter = \Drupal::entityTypeManager()
      ->getStorage('simplenews_newsletter')
      ->load('announcements');
    if (!$newsletter) {
      return;
    }

    $body = '';
    if ($node->hasField('field_announcement_body') && !$node->get('field_announcement_body')->isEmpty()) {
      $body = $node->get('field_announcement_body')->value;
    }

    $url = \Drupal::request()->getSchemeAndHttpHost() . '/announcements/' . $node->id();

    $issue = \Drupal::entityTypeManager()->getStorage('simplenews_issue')->create([
      'title'           => $node->getTitle(),
      'simplenews_issue' => ['target_id' => $newsletter->id()],
      'body'            => [
        'value'  => $body . '<p><a href="' . $url . '">Read on the website →</a></p>',
        'format' => 'basic_html',
      ],
      'status' => 1,
    ]);
    $issue->save();

    \Drupal::service('simplenews.mailer')->sendIssue($issue);
  }
  catch (\Exception $e) {
    \Drupal::logger('mlp_members')->error(
      'Failed to send announcement newsletter: @message',
      ['@message' => $e->getMessage()]
    );
  }
}

