{#
/**
 * @file block--meadow-lane-about.html.twig
 * Meadow Lane Park — Homepage "About Us" section block.
 *
 * Place this block in the Content region on the front page
 * via Structure > Block layout > Front page.
 *
 * Machine name: meadow_lane_about
 * Create as a Custom block in Structure > Block layout > Add custom block.
 */
#}
<section class="hp-about" aria-label="{{ 'About Meadow Lane Park'|t }}">
  <div class="container">
    <div class="hp-about__grid">

      <div class="hp-about__text">
        <span class="section-label">{{ 'About our community'|t }}</span>
        <h2>{{ 'Own your home.<br>Own your community.'|t|raw }}</h2>
        <p>
          {{ 'Meadow Lane Park is a seasonal, resident-owned community — incorporated in 2018. That means the land beneath your home is owned collectively by the members, keeping costs stable and giving every homeowner a real voice in how the community is run.'|t }}
        </p>
        <p>
          {{ 'Unlike traditional land-lease parks, buying here makes you a co-owner of the community itself. That\'s security, belonging, and a true stake in where you spend your summers.'|t }}
        </p>
        <a href="/about" class="btn btn--outline" style="margin-top: var(--space-4);">
          {{ 'What does resident-owned mean?'|t }}
        </a>
      </div>

      <div class="hp-about__image-col">
        {# If the block has a field_image, render it; otherwise show a styled placeholder #}
        {% if content.field_image %}
          <div class="hp-about__image">{{ content.field_image }}</div>
        {% else %}
          <div class="hp-about__image hp-about__image--placeholder" aria-hidden="true">
            <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
              <rect width="400" height="300" fill="#DCF0EB"/>
              <ellipse cx="200" cy="180" rx="200" ry="60" fill="#B8D4E8" opacity="0.6"/>
              <rect x="140" y="60" width="20" height="120" fill="#4A7C6F" opacity="0.5"/>
              <polygon points="130,80 150,20 170,80" fill="#2C5F3A" opacity="0.6"/>
              <rect x="200" y="80" width="18" height="100" fill="#4A7C6F" opacity="0.4"/>
              <polygon points="191,98 209,38 227,98" fill="#2C5F3A" opacity="0.5"/>
              <rect x="240" y="95" width="16" height="85" fill="#4A7C6F" opacity="0.4"/>
              <polygon points="232,110 248,55 264,110" fill="#2C5F3A" opacity="0.5"/>
            </svg>
          </div>
        {% endif %}

        {# Stat callout card #}
        <div class="hp-about__stat-card">
          <div class="hp-about__stat-number">2018</div>
          <div class="hp-about__stat-label">{{ 'Year incorporated as resident-owned'|t }}</div>
        </div>
      </div>

    </div>
  </div>
</section>
