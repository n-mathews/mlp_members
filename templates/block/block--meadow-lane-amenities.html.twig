{#
/**
 * @file block--meadow-lane-amenities.html.twig
 * Meadow Lane Park — Homepage "Amenities" section block.
 *
 * Place in the Content region on the front page.
 * Machine name: meadow_lane_amenities
 */
#}
<section class="hp-amenities" aria-label="{{ 'Community amenities'|t }}">
  <div class="container">

    <div class="hp-amenities__header">
      <span class="section-label">{{ 'What we offer'|t }}</span>
      <h2>{{ 'Community amenities'|t }}</h2>
      <p>{{ 'Everything you need for a great seasonal getaway on the St. Lawrence River.'|t }}</p>
    </div>

    <div class="hp-amenities__grid">

      <div class="hp-amenity-card">
        <div class="hp-amenity-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 20 Q7 15 12 17 Q17 19 20 15" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M2 17 Q6 13 10 15 Q14 17 18 13 Q20 11 22 13" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.6"/>
            <circle cx="12" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="hp-amenity-card__title">{{ 'River access'|t }}</h3>
        <p class="hp-amenity-card__desc">{{ 'Private waterfront access to the St. Lawrence River with docking and boat launch for members.'|t }}</p>
      </div>

      <div class="hp-amenity-card">
        <div class="hp-amenity-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 21 L3 10 L12 4 L21 10 L21 21 Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
            <rect x="9" y="14" width="6" height="7" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </div>
        <h3 class="hp-amenity-card__title">{{ 'Community tent'|t }}</h3>
        <p class="hp-amenity-card__desc">{{ 'A large community tent hosts member events, socials, and seasonal gatherings throughout the summer.'|t }}</p>
      </div>

      <div class="hp-amenity-card">
        <div class="hp-amenity-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 12 Q12 8 15 12 Q12 16 9 12Z" fill="currentColor" opacity="0.4"/>
          </svg>
        </div>
        <h3 class="hp-amenity-card__title">{{ 'Recreation'|t }}</h3>
        <p class="hp-amenity-card__desc">{{ 'Walking paths, green spaces, and seasonal recreational areas in beautifully maintained grounds.'|t }}</p>
      </div>

      <div class="hp-amenity-card">
        <div class="hp-amenity-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="4" width="18" height="17" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 10 L21 10" stroke="currentColor" stroke-width="1.2"/>
            <path d="M8 4 L8 10" stroke="currentColor" stroke-width="1.2"/>
            <path d="M16 4 L16 10" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </div>
        <h3 class="hp-amenity-card__title">{{ 'Seasonal events'|t }}</h3>
        <p class="hp-amenity-card__desc">{{ 'A full season of community events — openings, socials, and celebrations for members and their families.'|t }}</p>
      </div>

      <div class="hp-amenity-card">
        <div class="hp-amenity-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M2 11 L22 11" stroke="currentColor" stroke-width="1.2"/>
            <path d="M7 7 L7 4 Q7 2 9 2 L15 2 Q17 2 17 4 L17 7" stroke="currentColor" stroke-width="1.2" fill="none"/>
          </svg>
        </div>
        <h3 class="hp-amenity-card__title">{{ 'Manufactured homes'|t }}</h3>
        <p class="hp-amenity-card__desc">{{ 'Well-maintained manufactured homes in a range of sizes — affordable seasonal living right on the St. Lawrence River.'|t }}</p>
      </div>

    </div>{# /.hp-amenities__grid #}

    <div class="hp-amenities__cta">
      <a href="/amenities" class="btn btn--outline">{{ 'See all amenities'|t }}</a>
    </div>

  </div>
</section>
