{#
/**
 * @file mlp-events.html.twig
 * Meadow Lane Park — events calendar page.
 */
#}
<div class="events-page">

  {# ── Add event button ─────────────────────────────── #}
  {% if can_add %}
    <div class="events-page__actions">
      <a href="/node/add/event" class="btn btn--primary btn--sm">
        <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
          <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        {{ 'Add event'|t }}
      </a>
    </div>
  {% endif %}

  {# ── FullCalendar ──────────────────────────────────── #}
  <div class="events-calendar-wrap">
    <div id="mlp-fullcalendar"></div>
  </div>

  {# ── Upcoming events list ──────────────────────────── #}
  <section class="events-list-section">
    <h2 class="events-list-section__title">{{ 'Upcoming events'|t }}</h2>

    {% if events %}
      <div class="events-list">
        {% for event in events %}
          <article class="event-card{{ event.featured ? ' event-card--featured' : '' }}"
                   data-event-id="{{ event.id }}">

            <div class="event-card__date-block">
              <span class="event-card__date">{{ event.date|date('M j') }}</span>
              <span class="event-card__time">{{ event.all_day ? 'All Day'|t : event.date|date('g:i A') }}</span>
            </div>

            <div class="event-card__body">
              <h3 class="event-card__title">{{ event.title }}</h3>

              {% if event.location %}
                <p class="event-card__location">
                  <svg viewBox="0 0 16 16" fill="none" width="12" height="12" aria-hidden="true">
                    <path d="M8 1a4.5 4.5 0 00-4.5 4.5C3.5 9.5 8 15 8 15s4.5-5.5 4.5-9.5A4.5 4.5 0 008 1z" stroke="currentColor" stroke-width="1.3"/>
                    <circle cx="8" cy="5.5" r="1.5" stroke="currentColor" stroke-width="1.3"/>
                  </svg>
                  {{ event.location }}
                </p>
              {% endif %}

              {% if not event.all_day and event.end_date %}
                <p class="event-card__end">
                  {{ 'Until'|t }} {{ event.end_date|date('g:i A') }}
                </p>
              {% endif %}

              {% if event.body %}
                <div class="event-card__desc">
                  {{ event.body|striptags|slice(0, 200) }}{% if event.body|striptags|length > 200 %}…{% endif %}
                </div>
              {% endif %}

              {% if event.link %}
                <a href="{{ event.link.url }}" class="event-card__link" target="_blank" rel="noopener">
                  {{ event.link.title }}
                </a>
              {% endif %}

              {% if event.can_edit or event.can_delete %}
                <div class="event-card__actions">
                  {% if event.can_edit %}
                    <a href="/node/{{ event.id }}/edit" class="event-card__action event-card__action--edit">
                      <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                        <path d="M11.5 2.5l2 2L5 13H3v-2L11.5 2.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                      </svg>
                      {{ 'Edit'|t }}
                    </a>
                  {% endif %}
                  {% if event.can_delete %}
                    <a href="/node/{{ event.id }}/delete" class="event-card__action event-card__action--delete">
                      <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                        <path d="M3 4h10M6 4V3h4v1M5 4v8h6V4H5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ 'Delete'|t }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>

          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="member-notice">
        <p>{{ 'No upcoming events scheduled.'|t }}</p>
      </div>
    {% endif %}

  </section>

</div>

{# FullCalendar CDN #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script>
(function () {
  'use strict';
  document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('mlp-fullcalendar');
    if (!el || typeof FullCalendar === 'undefined') return;
    var calendar = new FullCalendar.Calendar(el, {
      initialView: 'dayGridMonth',
      headerToolbar: {
        left:   'prev,next today',
        center: 'title',
        right:  'dayGridMonth,listMonth'
      },
      buttonText: { today: 'Today', month: 'Month', list: 'List' },
      events: '/events/feed.json',
      eventColor: '#4A7C6F',
      eventTextColor: '#ffffff',
      eventDisplay: 'block',
      height: 'auto',
      eventClick: function (info) {
        var target = document.querySelector('[data-event-id="' + info.event.id + '"]');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          target.classList.add('is-highlighted');
          setTimeout(function () { target.classList.remove('is-highlighted'); }, 2000);
        }
      },
    });
    calendar.render();
  });
})();
</script>
