{#
/**
 * @file mlp-announcements.html.twig
 * Meadow Lane Park — announcements listing page.
 */
#}
<div class="member-announcements-page">

  {# ── Header ───────────────────────────────────────── #}
  <div class="member-announcements-page__header">
    <h2 class="member-announcements-page__title">{{ 'Announcements'|t }}</h2>
    <div class="member-announcements-page__header-right">
      {% if total %}
        <span class="member-announcements-page__count">
          {{ total }} {{ total == 1 ? 'announcement'|t : 'announcements'|t }}
        </span>
      {% endif %}
      {% if can_add %}
        <a href="/node/add/announcement" class="btn btn--primary btn--sm">
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
            <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          {{ 'Add announcement'|t }}
        </a>
      {% endif %}
    </div>
  </div>

  {# ── Category filter bar ───────────────────────────── #}
  {% if categories %}
    <div class="member-filter-bar" role="navigation" aria-label="{{ 'Filter by category'|t }}">
      <a href="/announcements" class="member-filter-bar__tag{{ active_tid == 0 ? ' is-active' : '' }}">
        {{ 'All'|t }}
      </a>
      {% for cat in categories %}
        <a href="/announcements?category={{ cat.id }}"
           class="member-filter-bar__tag{{ active_tid == cat.id ? ' is-active' : '' }}">
          {{ cat.name }}
        </a>
      {% endfor %}
    </div>
  {% endif %}

  {# ── Listing ───────────────────────────────────────── #}
  {% if items %}
    <div class="member-announcement-list">
      {% for item in items %}
        <article class="member-announcement-card{{ item.sticky ? ' member-announcement-card--sticky' : '' }}{{ item.featured ? ' member-announcement-card--featured' : '' }}">

          <div class="member-announcement-card__meta">
            {% if item.sticky %}
              <span class="member-announcement-card__pin" title="{{ 'Pinned'|t }}">
                <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                  <path d="M9.5 1a1 1 0 011 1v1.5h1a1 1 0 010 2H11v5l1 2H4l1-2V5.5H4a1 1 0 010-2h1V2a1 1 0 011-1h3.5z"/>
                </svg>
                {{ 'Pinned'|t }}
              </span>
            {% endif %}
            {% if item.featured %}
              <span class="member-announcement-card__badge">{{ 'Featured'|t }}</span>
            {% endif %}
            {% for cat in item.categories %}
              <a href="/announcements?category={{ cat.id }}" class="member-announcement-card__cat">
                {{ cat.name }}
              </a>
            {% endfor %}
            <time class="member-announcement-card__date" datetime="{{ item.created|format_date('html_datetime') }}">
              {{ item.created|format_date('medium') }}
            </time>
          </div>

          <h3 class="member-announcement-card__title">
            <a href="/announcements/{{ item.id }}" class="member-announcement-card__link">
              {{ item.title }}
            </a>
          </h3>

          {% if item.body %}
            <div class="member-announcement-card__excerpt">
              {{ item.body|striptags|slice(0, 280) }}{% if item.body|striptags|length > 280 %}…{% endif %}
            </div>
          {% endif %}

          <a href="/announcements/{{ item.id }}" class="member-announcement-card__read-more">
            {{ 'Read more'|t }} →
          </a>

          {% if item.can_edit or item.can_delete %}
            <div class="event-card__actions">
              {% if item.can_edit %}
                <a href="/node/{{ item.id }}/edit" class="event-card__action event-card__action--edit">
                  <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                    <path d="M11.5 2.5l2 2L5 13H3v-2L11.5 2.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                  </svg>
                  {{ 'Edit'|t }}
                </a>
              {% endif %}
              {% if item.can_delete %}
                <a href="/node/{{ item.id }}/delete" class="event-card__action event-card__action--delete">
                  <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                    <path d="M3 4h10M6 4V3h4v1M5 4v8h6V4H5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {{ 'Delete'|t }}
                </a>
              {% endif %}
            </div>
          {% endif %}

        </article>
      {% endfor %}
    </div>

    {# ── Pager ─────────────────────────────────────────── #}
    {% if total_pages > 1 %}
      <nav class="member-pager" aria-label="{{ 'Announcements pages'|t }}">
        {% set cat_param = active_tid ? '&category=' ~ active_tid : '' %}
        {% if page > 0 %}
          <a href="?page={{ page - 1 }}{{ cat_param }}" class="member-pager__btn">← {{ 'Previous'|t }}</a>
        {% endif %}
        <span class="member-pager__info">
          {{ 'Page'|t }} {{ page + 1 }} {{ 'of'|t }} {{ total_pages }}
        </span>
        {% if page < total_pages - 1 %}
          <a href="?page={{ page + 1 }}{{ cat_param }}" class="member-pager__btn">{{ 'Next'|t }} →</a>
        {% endif %}
      </nav>
    {% endif %}

  {% else %}
    <div class="member-notice">
      {% if active_tid %}
        <p>{{ 'No announcements found in this category.'|t }}</p>
      {% else %}
        <p>{{ 'No announcements have been posted yet.'|t }}</p>
      {% endif %}
    </div>
  {% endif %}

</div>
