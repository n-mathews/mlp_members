{#
/**
 * @file page--inner.html.twig
 * Meadow Lane Park — base layout for all inner (non-front) pages.
 *
 * Provides the page banner (title + breadcrumb), a content area,
 * and optional sidebar. Specific page overrides (about, amenities, etc.)
 * can use this as a visual reference; Drupal will use the most specific
 * template match, so page--node--about.html.twig takes precedence over
 * this one when that node is viewed.
 *
 * Used directly for generic nodes and basic pages that don't have a
 * more specific template.
 */
#}
<div class="site-wrapper">

  {{ include('@meadow_lane/partials/site-header.html.twig') }}

  {# ── Page banner ──────────────────────────────────────── #}
  {% block page_banner %}
    <div class="page-banner">
      <div class="page-banner__inner container">
        {% if page.breadcrumb %}
          <nav class="page-banner__breadcrumb" aria-label="{{ 'Breadcrumb'|t }}">
            {{ page.breadcrumb }}
          </nav>
        {% endif %}
        <h1 class="page-banner__title">
          {{ page.content['#title'] ?? node.label ?? '' }}
        </h1>
      </div>
    </div>
  {% endblock %}

  {# ── Highlighted messages ─────────────────────────────── #}
  {% if page.highlighted %}
    <div class="layout-highlighted container" role="complementary">
      {{ page.highlighted }}
    </div>
  {% endif %}

  {# ── Main content ─────────────────────────────────────── #}
  <main id="main-content" class="layout-main" role="main" tabindex="-1">

    {% if page.content_top %}
      <div class="layout-content-top container">{{ page.content_top }}</div>
    {% endif %}

    <div class="layout-content container">
      {% if page.sidebar_first %}
        <div class="layout-two-col layout-two-col--sidebar">
          <div class="layout-main-col">{{ page.content }}</div>
          <aside class="layout-sidebar" aria-label="{{ 'Sidebar'|t }}">
            {{ page.sidebar_first }}
          </aside>
        </div>
      {% else %}
        {{ page.content }}
      {% endif %}
    </div>

    {% if page.content_bottom %}
      <div class="layout-content-bottom container">{{ page.content_bottom }}</div>
    {% endif %}

  </main>

  {{ include('@meadow_lane/partials/site-footer.html.twig') }}

</div>{# /.site-wrapper #}
