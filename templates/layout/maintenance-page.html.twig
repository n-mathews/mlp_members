{#
/**
 * @file maintenance-page.html.twig
 * Meadow Lane Park — maintenance mode page.
 *
 * Drupal's maintenance page variables:
 *   - site_name:   From Configuration → System → Basic site settings → Site name
 *   - site_slogan: From Configuration → System → Basic site settings → Slogan
 *   - content:     The maintenance message from
 *                  Configuration → Development → Maintenance mode → Message
 *   - logo:        Theme logo URL (unused — we use our PNG directly)
 *   - db_offline:  TRUE if DB is unavailable
 */
#}
<!DOCTYPE html>
<html{{ html_attributes }}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ site_name }} — {{ 'Be right back'|t }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: Georgia, serif; }
    body {
      min-height: 100vh;
      background-color: #1E2D28;
      background-image: url('{{ base_path ~ directory }}/images/hero-aerial.jpg');
      background-size: cover;
      background-position: center 40%;
      background-repeat: no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: linear-gradient(to bottom, rgba(28,45,38,0.75) 0%, rgba(28,45,38,0.88) 100%);
      z-index: 0;
    }
    .maintenance-card {
      position: relative;
      z-index: 1;
      max-width: 560px;
      width: 100%;
      text-align: center;
    }
    .maintenance-logo {
      width: 80px;
      height: auto;
      margin: 0 auto 1.75rem;
    }
    .maintenance-logo img { width: 80px; height: auto; display: block; }
    .maintenance-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      color: rgba(255,255,255,0.75);
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 1.5rem;
    }
    .maintenance-badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #6E9E92;
    }
    .maintenance-heading {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: normal;
      font-style: italic;
      color: white;
      line-height: 1.15;
      margin-bottom: 1.25rem;
    }
    .maintenance-message {
      font-family: -apple-system, 'Helvetica Neue', sans-serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.7;
      margin-bottom: 2rem;
    }
    .maintenance-message p { margin-bottom: 0.5em; }
    .maintenance-message p:last-child { margin-bottom: 0; }
    .maintenance-divider {
      width: 48px; height: 1.5px;
      background: rgba(110,158,146,0.6);
      margin: 2rem auto;
      border: none;
    }
    .maintenance-site-name {
      font-size: 0.875rem;
      font-style: normal;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.06em;
    }
    .maintenance-slogan {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.3);
      margin-top: 0.35rem;
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="maintenance-card">

    <div class="maintenance-logo" aria-hidden="true">
      <img src="{{ base_path ~ directory }}/images/logo-icon.png"
           alt="{{ site_name }}"
           width="80"/>
    </div>

    <div class="maintenance-badge">
      <span class="maintenance-badge-dot"></span>
      {{ 'Back shortly'|t }}
    </div>

    {#
      The h1 uses site_name if available, otherwise falls back to a
      translated default. Editors can customise the site name at
      Configuration → System → Basic site settings.
    #}
    <h1 class="maintenance-heading">
      {% if site_name %}
        {{ site_name }}
      {% else %}
        {{ 'Meadow Lane Park'|t }}
      {% endif %}
    </h1>

    <div class="maintenance-message">
      {#
        The admin maintenance message is passed via page.highlighted and
        page.content — set at:
        Configuration → Development → Maintenance mode → Message to display.
      #}
      {% if page.highlighted %}{{ page.highlighted }}{% endif %}
      {% if page.content %}
        {{ page.content }}
      {% else %}
        <p>{{ 'Our website is currently undergoing scheduled maintenance. We\'ll be back shortly.'|t }}</p>
      {% endif %}
    </div>

    <hr class="maintenance-divider">

    <p class="maintenance-site-name">
      {{ site_name }} &middot; {{ '1000 Islands, New York'|t }}
    </p>

    {% if site_slogan %}
      <p class="maintenance-slogan">{{ site_slogan }}</p>
    {% endif %}

  </div>
</body>
</html>
