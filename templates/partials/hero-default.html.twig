{#
/**
 * @file hero-default.html.twig
 * Meadow Lane Park — default hero section content.
 *
 * Used as fallback when no block is assigned to the Hero region.
 * Included by page--front.html.twig.
 *
 * Variables available from parent template:
 *   - hero_tagline: Main headline (from theme settings).
 *   - hero_subtext: Supporting paragraph (from theme settings).
 */
#}
<section class="hero" aria-label="{{ 'Welcome to Meadow Lane Park'|t }}">

  <div class="hero__scenery" aria-hidden="true">
    {{ include('@meadow_lane/partials/hero-scenery.svg.twig') }}
  </div>

  <div class="hero__content">
    <div class="hero__badge">
      <span class="hero__badge-dot"></span>
      {{ 'Resident-Owned Since 2018'|t }}
    </div>

    <h1>
      {{ hero_tagline|default('Life on the'|t) }}<br>
      <em>{{ 'Thousand Islands'|t }}</em>
    </h1>

    <p class="hero__lead">
      {{ hero_subtext|default('A seasonal community on the St. Lawrence River — resident-owned and proudly run by the people who call it home.'|t) }}
    </p>

    <div class="hero__actions">
      <a href="/homes-for-sale" class="btn btn--white">{{ 'View seasonal homes'|t }}</a>
      <a href="/about" class="btn btn--ghost-light">{{ 'Learn about us'|t }}</a>
    </div>
  </div>

</section>

{# ── Stats strip ──────────────────────────────────────── #}
<div class="stats-strip" aria-label="{{ 'Community at a glance'|t }}">
  <div class="stats-strip__item">
    <div class="stats-strip__number">100%</div>
    <div class="stats-strip__label">{{ 'Resident-owned'|t }}</div>
  </div>
  <div class="stats-strip__item">
    <div class="stats-strip__number">20 {{ 'Acres'|t }}</div>
    <div class="stats-strip__label">{{ 'Park-like setting'|t }}</div>
  </div>
  <div class="stats-strip__item">
    <div class="stats-strip__number">68+</div>
    <div class="stats-strip__label">{{ 'Slip marina complex'|t }}</div>
  </div>
  <div class="stats-strip__item">
    <div class="stats-strip__number">{{ 'Seasonal'|t }}</div>
    <div class="stats-strip__label">{{ 'Homes &amp; community'|t }}</div>
  </div>
</div>
