{#
/**
 * @file hero-scenery.svg.twig
 * Meadow Lane Park — decorative SVG scenery overlay for the hero section.
 * Renders silhouetted pine trees, a sun/moon disc, and river wave shapes.
 * Intended to be placed inside .hero__scenery with aria-hidden="true".
 */
#}
<svg
  viewBox="0 0 600 560"
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="xMaxYMid slice"
  style="position:absolute;inset:0;width:100%;height:100%;opacity:.18;"
  aria-hidden="true"
  focusable="false"
>
  {# Sun / moon disc #}
  <ellipse cx="480" cy="100" rx="140" ry="140" fill="white"/>

  {# Pine tree — left #}
  <rect x="260" y="120" width="30" height="220" fill="white"/>
  <polygon points="245,130 275,40 305,130" fill="white"/>

  {# Pine tree — centre #}
  <rect x="340" y="160" width="28" height="180" fill="white"/>
  <polygon points="326,170 354,90 382,170" fill="white"/>

  {# Pine tree — right #}
  <rect x="420" y="200" width="24" height="160" fill="white"/>
  <polygon points="408,210 432,140 456,210" fill="white"/>

  {# River waves #}
  <path d="M0 400 Q100 380 200 400 Q300 420 400 395 Q500 370 600 390 L600 560 L0 560Z" fill="white"/>
  <path d="M0 420 Q150 400 300 415 Q450 430 600 410 L600 560 L0 560Z" fill="white" opacity="0.5"/>
</svg>
