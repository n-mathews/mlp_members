{#
/**
 * @file site-header.html.twig
 * Meadow Lane Park — site header and primary navigation.
 *
 * The primary menu is rendered directly from the menu tree rather than
 * through Drupal's block system, which adds unavoidable wrapper divs that
 * break the flex nav layout. The menu tree is passed via preprocess.
 *
 * Variables:
 *   - primary_menu_items: Array of menu link items (from preprocess).
 *   - page.header: Header region — account menu block lives here.
 *   - page.header_top: Optional utility bar region.
 *   - show_member_login: Boolean from theme settings.
 *   - logged_in: TRUE if user is logged in.
 */
#}
<header class="layout-header" role="banner">

  {% if page.header_top %}
    <div class="header-utility">
      <div class="header-utility__inner container">
        {{ page.header_top }}
      </div>
    </div>
  {% endif %}

  <nav class="site-nav" aria-label="{{ 'Site navigation'|t }}">

    {# ── Logo ──────────────────────────────────────────── #}
    <a class="nav__logo" href="{{ path('<front>') }}" rel="home" aria-label="{{ 'Meadow Lane Park — home'|t }}">
      <div class="nav__logo-mark" aria-hidden="true">
        {{ include('@meadow_lane/partials/logo-mark.svg.twig') }}
      </div>
      <div class="nav__brand">
        {{ 'Meadow Lane Park'|t }}
        <span class="nav__brand-sub">{{ '1000 Islands · New York'|t }}</span>
      </div>
    </a>

    {# ── Mobile toggle ──────────────────────────────────── #}
    <button
      class="nav__toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="{{ 'Toggle navigation menu'|t }}"
    >
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>

    {# ── Primary menu ───────────────────────────────────── #}
    {# Rendered directly from menu items — no block wrapper overhead #}
    <ul class="nav__menu" id="primary-nav" role="list">

      {% if primary_menu_items %}
        {% for item in primary_menu_items %}
          <li class="nav__menu-item{{ item.in_active_trail ? ' is-active' : '' }}">
            {{ link(item.title, item.url) }}
          </li>
        {% endfor %}
      {% elseif page.primary_menu %}
        {# Fallback: render the region block if preprocess items unavailable #}
        <li class="nav__menu-item nav__menu-item--region">{{ page.primary_menu }}</li>
      {% elseif logged_in %}
        <li class="nav__admin-hint">
          <a href="{{ path('block.admin_demo', {'theme': 'meadow_lane'}) }}" class="nav__admin-hint-link">
            ⚙ {{ 'Set up navigation at Structure → Block layout'|t }}
          </a>
        </li>
      {% endif %}

{# Member Login CTA #}
      {% if show_member_login %}
        <li class="nav__menu-item">
          <a href="{{ member_login_url|default('https://app.easyhoa.com') }}" class="nav__member-btn"{% if member_login_url starts with 'http' %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ 'Member Login'|t }}</a>
        </li>
      {% endif %}

    </ul>

  </nav>
</header>
