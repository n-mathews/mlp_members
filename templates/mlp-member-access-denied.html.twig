{#
/**
 * @file mlp-member-access-denied.html.twig
 * Shown to anonymous visitors who try to access the member portal.
 */
#}
<div class="member-access-denied">
  <div class="member-access-denied__inner">
    <div class="member-access-denied__icon" aria-hidden="true">
      <svg viewBox="0 0 48 48" fill="none" width="48" height="48"><circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="1.5"/><path d="M24 14v12M24 32v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </div>
    <h2>{{ 'Members only'|t }}</h2>
    <p>{{ 'This area is for Meadow Lane Park members. Please log in to access community announcements, events, and documents.'|t }}</p>
    <div class="member-access-denied__actions">
      <a href="/user/login?destination=/member" class="btn btn--primary">{{ 'Log in'|t }}</a>
    </div>
  </div>
</div>
