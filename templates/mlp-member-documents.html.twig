{#
/**
 * @file mlp-member-documents.html.twig
 * Meadow Lane Park — member documents & forms page.
 * Recursive folder tree, collapsed by default, alphabetically sorted.
 */
#}

{# ── Recursive macro for folder tree ──────────────────── #}
{% macro folder_tree(node, depth) %}
  {% import _self as self %}

  {# Files at this level #}
  {% if node.files %}
    <ul class="member-doc-list">
      {% for file in node.files %}
        <li class="member-doc-item">
          <a href="{{ file.webViewLink }}" class="member-doc-item__link" target="_blank" rel="noopener noreferrer">
            <span class="member-doc-item__icon" aria-hidden="true">
              {% if 'pdf' in file.mimeType %}
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              {% elseif 'spreadsheet' in file.mimeType or 'excel' in file.mimeType %}
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 9h18M3 15h18M9 3v18" stroke="currentColor" stroke-width="1.2"/></svg>
              {% elseif 'document' in file.mimeType or 'word' in file.mimeType %}
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6M16 13H8M16 17H8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              {% endif %}
            </span>
            <span class="member-doc-item__name">{{ file.name }}</span>
            {% if file.modifiedTime %}
              <span class="member-doc-item__meta">{{ file.modifiedTime|date('M j, Y') }}</span>
            {% endif %}
            <svg class="member-doc-item__arrow" viewBox="0 0 16 16" fill="none" width="12" height="12" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {# Subfolders at this level #}
  {% for child in node.children %}
    <details class="member-doc-folder member-doc-folder--depth-{{ depth }}">
      <summary class="member-doc-folder__summary">
        <svg class="member-doc-folder__icon" viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true">
          <path d="M2 6a2 2 0 012-2h4l2 2h6a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        <span class="member-doc-folder__name">{{ child.name }}</span>
        <svg class="member-doc-folder__chevron" viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <div class="member-doc-folder__contents">
        {{ self.folder_tree(child, depth + 1) }}
      </div>
    </details>
  {% endfor %}
{% endmacro %}

{% import _self as self %}

<div class="member-documents">

  <div class="member-documents__header">
    <h2>{{ 'Documents &amp; Forms'|t }}</h2>
    {% if is_admin %}
      <a href="/member/documents/refresh" class="btn btn--sm btn--outline">{{ 'Refresh from Drive'|t }}</a>
    {% endif %}
  </div>

  {% if not drive_enabled %}
    <div class="member-notice">
      <p>{{ 'Documents are not yet available. Please check back soon.'|t }}</p>
    </div>

  {% elseif sections is empty %}
    <div class="member-notice">
      <p>{{ 'No documents found. Ensure Google Drive folders are configured and shared with the service account.'|t }}</p>
    </div>

  {% else %}
    {% for section in sections %}
      <section class="member-doc-section">
        <h3 class="member-doc-section__title">{{ section.label }}</h3>
        <div class="member-doc-section__body">
          {{ self.folder_tree(section.subfolders, 1) }}
        </div>
      </section>
    {% endfor %}
  {% endif %}

</div>
