{#
/**
 * @file mlp-member-documents.html.twig
 * Meadow Lane Park — member documents & forms page.
 */
#}
<div class="member-documents">

  <div class="member-documents__header">
    <h2>{{ 'Documents &amp; Forms'|t }}</h2>
    {% if is_admin %}
      <a href="/member/documents/refresh" class="btn btn--sm btn--outline">{{ 'Refresh from Drive'|t }}</a>
    {% endif %}
  </div>

  {% if not drive_enabled %}
    <div class="member-notice">
      <p>{{ 'Documents are not yet available. Please check back soon.'|t }}</p>
    </div>
  {% elseif sections is empty %}
    <div class="member-notice">
      <p>{{ 'No documents found. Ensure the Google Drive folders are configured and shared with the service account.'|t }}</p>
    </div>
  {% else %}
    {% for section in sections %}
      <section class="member-doc-section">
        <h3 class="member-doc-section__title">{{ section.label }}</h3>

        {% if section.files is empty %}
          <p class="member-empty">{{ 'No files in this folder.'|t }}</p>
        {% else %}
          <ul class="member-doc-list">
            {% for file in section.files %}
              <li class="member-doc-item">
                <a href="{{ file.webViewLink }}" class="member-doc-item__link" target="_blank" rel="noopener noreferrer">
                  <span class="member-doc-item__icon" aria-hidden="true">
                    {% if 'pdf' in file.mimeType %}
                      <svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 13h1.5a1.5 1.5 0 010 3H9v-3zM9 13V11M15 13v5M12 13v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    {% elseif 'spreadsheet' in file.mimeType or 'excel' in file.mimeType %}
                      <svg viewBox="0 0 24 24" fill="none" width="18" height="18"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 9h18M3 15h18M9 3v18" stroke="currentColor" stroke-width="1.2"/></svg>
                    {% else %}
                      <svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    {% endif %}
                  </span>
                  <span class="member-doc-item__name">{{ file.name }}</span>
                  <span class="member-doc-item__meta">
                    {% if file.modifiedTime %}{{ file.modifiedTime|date('M j, Y') }}{% endif %}
                  </span>
                  <svg class="member-doc-item__arrow" viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      </section>
    {% endfor %}
  {% endif %}

</div>
