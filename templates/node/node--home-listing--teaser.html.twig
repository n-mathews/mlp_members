{#
/**
 * @file node--home-listing--teaser.html.twig
 * Meadow Lane Park — teaser card for a Home Listing node.
 *
 * Available variables:
 *   - node: The node entity.
 *   - label: The node title.
 *   - url: The node URL.
 *   - listing_price, listing_beds, listing_baths, listing_sqft,
 *     listing_address, listing_status: Preprocessed in meadow_lane.theme.
 *   - content: Rendered fields (use if needed for images, body, etc.)
 */
#}
<article{{ attributes.addClass('listing-card')
  .setAttribute('data-price', listing_price|default(0))
  .setAttribute('data-beds', listing_beds|default(0))
  .setAttribute('data-status', listing_status|default('available'))
}}>
  <a href="{{ url }}" class="listing-card__link" aria-label="{{ label }}">

    {# Image #}
    <div class="listing-card__image">
      {% if content.field_images %}
        {{ content.field_images }}
      {% endif %}

      {# Status badge #}
      {% if listing_status %}
        {% set badge_mod = listing_status|lower|replace({' ': '-'}) %}
        <span class="listing-card__badge listing-card__badge--{{ badge_mod }}">
          {{ listing_status|t }}
        </span>
      {% endif %}
    </div>

    {# Body #}
    <div class="listing-card__body">
      {% if listing_price %}
        <div class="listing-card__price">
          ${{ listing_price|number_format(0, '.', ',') }}
        </div>
      {% endif %}

      {% if listing_address %}
        <div class="listing-card__address">{{ listing_address }}</div>
      {% elseif label %}
        <div class="listing-card__address">{{ label }}</div>
      {% endif %}

      <div class="listing-card__details">
        {% if listing_beds %}
          <div class="listing-card__detail">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <rect x="1" y="6" width="12" height="7" rx="1" stroke="currentColor" stroke-width="1.2"/>
              <path d="M1 9L4.5 6.5L7 8.5L9.5 6.5L13 9" stroke="currentColor" stroke-width="1" fill="none"/>
            </svg>
            {{ listing_beds }} {{ 'bed'|t }}
          </div>
        {% endif %}
        {% if listing_baths %}
          <div class="listing-card__detail">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M5 7 L7 5 L9 7" stroke="currentColor" stroke-width="1" fill="none"/>
            </svg>
            {{ listing_baths }} {{ 'bath'|t }}
          </div>
        {% endif %}
        {% if listing_sqft %}
          <div class="listing-card__detail">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <rect x="2" y="2" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            {{ listing_sqft|number_format(0, '.', ',') }} {{ 'sq ft'|t }}
          </div>
        {% endif %}
      </div>
    </div>

  </a>
</article>
