{#
/**
 * @file node--home-listing--full.html.twig
 * Meadow Lane Park — full detail page for a Home Listing node.
 *
 * Attaches the gallery library for the photo lightbox.
 */
#}
{{ attach_library('meadow_lane/gallery') }}

<article{{ attributes.addClass('listing-detail') }}>

  {# ── Photo gallery ────────────────────────────────────── #}
  {% if content.field_images['#items'] is not empty or content.field_images|render|trim %}
    {% set image_count = content.field_images['#items']|length %}
    <div class="listing-gallery{{ image_count == 1 ? ' listing-gallery--single' : '' }}"
         role="button"
         tabindex="0"
         aria-label="{{ 'Open photo gallery'|t }}">

      {% for i in 0..(image_count - 1) %}
        <div class="listing-gallery__item">
          {{- content.field_images[i] -}}
          {% if i == 2 and image_count > 3 %}
            <div class="listing-gallery__overlay">
              {{ 'View all %count photos'|t({'%count': image_count}) }}
            </div>
          {% endif %}
        </div>
      {% endfor %}

    </div>
  {% endif %}

  <div class="listing-detail__body layout-two-col layout-two-col--sidebar">

    {# Left: main info #}
    <div class="listing-detail__main">

      {# Price + status #}
      <div class="listing-detail__price-row">
        {% if listing_price %}
          <div class="listing-detail__price">${{ listing_price|number_format(0, '.', ',') }}</div>
        {% endif %}
        {% if listing_status %}
          <span class="listing-card__badge listing-card__badge--{{ listing_status|lower|replace({' ': '-'}) }}">
            {{ listing_status|t }}
          </span>
        {% endif %}
      </div>

      {% if listing_address %}
        <p class="listing-detail__address">{{ listing_address }}</p>
      {% endif %}

      {# Key specs #}
      {% if listing_beds or listing_baths or listing_sqft %}
        <div class="listing-detail__specs">
          {% if listing_beds %}
            <div class="listing-detail__spec-item">
              <span class="listing-detail__spec-value">{{ listing_beds }}</span>
              <span class="listing-detail__spec-label">{{ 'Bedrooms'|t }}</span>
            </div>
          {% endif %}
          {% if listing_baths %}
            <div class="listing-detail__spec-item">
              <span class="listing-detail__spec-value">{{ listing_baths }}</span>
              <span class="listing-detail__spec-label">{{ 'Bathrooms'|t }}</span>
            </div>
          {% endif %}
          {% if listing_sqft %}
            <div class="listing-detail__spec-item">
              <span class="listing-detail__spec-value">{{ listing_sqft|number_format(0, '.', ',') }}</span>
              <span class="listing-detail__spec-label">{{ 'Sq Ft'|t }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# Body / description #}
      {% if content.body %}
        <div class="prose">{{ content.body }}</div>
      {% endif %}

      {# Remaining fields #}
      {{ content|without('field_images', 'body', 'field_price', 'field_bedrooms', 'field_bathrooms', 'field_sqft', 'field_address', 'field_status') }}

    </div>

    {# Right: sidebar #}
    <aside class="listing-detail__sidebar">
      <div class="card card--raised">
        <h2 class="card__title">{{ 'About this home'|t }}</h2>
        <p class="card__body" style="margin-bottom: 1.25rem;">
          {{ 'To enquire about this home, please contact the homeowner directly. All sale enquiries are handled by the individual seller.'|t }}
        </p>
        <a href="/ownership" class="btn btn--outline" style="width:100%; justify-content:center; margin-top:.75rem;">
          {{ 'How ownership works'|t }}
        </a>
      </div>
    </aside>

  </div>

</article>
