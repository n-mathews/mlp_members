{#
/**
 * @file mlp-history.html.twig
 * Meadow Lane Park — community history page.
 */
#}
<div class="history-page">

  {# ── Google Photos album ──────────────────────────────── #}
  <section class="history-photos">
    <div class="history-section__header">
      <h2 class="history-section__title">{{ 'Photo Album'|t }}</h2>
      {% if join_url %}
        <a href="{{ join_url }}" class="btn btn--primary btn--sm" target="_blank" rel="noopener">
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
            <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          {{ 'Add your photos'|t }}
        </a>
      {% endif %}
    </div>

    {% if photos_url %}
      <div class="history-photos__embed-wrap">
        {% if 'embed' in photos_url or 'googleusercontent' in photos_url %}
          <iframe src="{{ photos_url }}" class="history-photos__embed" frameborder="0" allowfullscreen loading="lazy" title="{{ 'Meadow Lane Park community photo album'|t }}"></iframe>
        {% else %}
          <a href="{{ photos_url }}" class="history-photos__link-card" target="_blank" rel="noopener">
            <div class="history-photos__link-card-inner">
              <svg viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true">
                <rect x="2" y="2" width="44" height="44" rx="8" fill="var(--clr-teal-light)" stroke="var(--clr-teal-pale)" stroke-width="1.5"/>
                <rect x="8" y="12" width="32" height="24" rx="3" stroke="var(--clr-teal)" stroke-width="1.5"/>
                <circle cx="16" cy="20" r="3" stroke="var(--clr-teal)" stroke-width="1.3"/>
                <path d="M8 30l9-8 7 7 5-4 9 8" stroke="var(--clr-teal)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div class="history-photos__link-card-text">
                <span class="history-photos__link-card-title">{{ 'View Community Photo Album'|t }}</span>
                <span class="history-photos__link-card-sub">{{ 'Opens in Google Photos'|t }}</span>
              </div>
              <svg viewBox="0 0 16 16" fill="none" width="16" height="16" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="var(--clr-teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        {% endif %}
      </div>
    {% else %}
      <div class="member-notice">
        <p>{{ 'The photo album has not been configured yet. Please check back soon.'|t }}</p>
      </div>
    {% endif %}
  </section>

  {# ── Pending submissions (managers only) ──────────────── #}
  {% if can_manage and pending %}
    <section class="history-pending">
      <div class="history-section__header">
        <h2 class="history-section__title">
          {{ 'Pending Review'|t }}
          <span class="history-pending__count">{{ pending|length }}</span>
        </h2>
      </div>
      <ul class="member-doc-list history-pending__list">
        {% for doc in pending %}
          <li class="member-doc-item history-pending__item">
            <div class="history-pending__info">
              <span class="history-pending__name">{{ doc.title }}</span>
              {% if doc.description %}
                <span class="member-doc-item__meta">{{ doc.description|striptags|slice(0,80) }}{% if doc.description|striptags|length > 80 %}…{% endif %}</span>
              {% endif %}
              <span class="history-pending__meta">
                {{ 'Submitted by'|t }} {{ doc.submitter }} &middot; {{ doc.created|format_date('short') }}
              </span>
            </div>
            <div class="history-pending__actions">
              {% if doc.file_url %}
                <a href="{{ doc.file_url }}" class="btn btn--outline btn--sm" target="_blank" rel="noopener">{{ 'View file'|t }}</a>
              {% endif %}
              <a href="/history/{{ doc.id }}/approve" class="btn btn--primary btn--sm">{{ 'Approve'|t }}</a>
              <a href="/node/{{ doc.id }}/delete" class="event-card__action event-card__action--delete">{{ 'Reject'|t }}</a>
            </div>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {# ── Historical documents ──────────────────────────────── #}
  <section class="history-documents">
    <div class="history-section__header">
      <h2 class="history-section__title">{{ 'Historical Documents'|t }}</h2>
      <div style="display:flex;gap:var(--space-3);flex-wrap:wrap;">
        {% if can_manage %}
          <a href="/history/submit" class="btn btn--primary btn--sm">
            <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
              <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            {{ 'Add document'|t }}
          </a>
        {% else %}
          <a href="/history/submit" class="btn btn--primary btn--sm">
            <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
              <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            {{ 'Submit a document'|t }}
          </a>
        {% endif %}
      </div>
    </div>

    {% if documents %}
      <ul class="member-doc-list">
        {% for doc in documents %}
          <li class="member-doc-item">
            {% if doc.file_url %}
              <a href="{{ doc.file_url }}" class="member-doc-item__link" target="_blank" rel="noopener noreferrer">
                <span class="member-doc-item__icon" aria-hidden="true">
                  {% if doc.file_mime and 'pdf' in doc.file_mime %}
                    <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  {% elseif doc.file_mime and 'image' in doc.file_mime %}
                    <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% endif %}
                </span>
                <span class="member-doc-item__name">{{ doc.title }}</span>
                {% if doc.description %}
                  <span class="member-doc-item__meta">{{ doc.description|striptags|slice(0,80) }}{% if doc.description|striptags|length > 80 %}…{% endif %}</span>
                {% endif %}
                <svg class="member-doc-item__arrow" viewBox="0 0 16 16" fill="none" width="12" height="12" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {% else %}
              <span class="member-doc-item__link member-doc-item__link--no-file">
                <span class="member-doc-item__name">{{ doc.title }}</span>
              </span>
            {% endif %}
            {% if can_manage %}
              <div class="event-card__actions" style="margin-top:var(--space-2);">
                <a href="/node/{{ doc.id }}/edit" class="event-card__action event-card__action--edit">{{ 'Edit'|t }}</a>
                <a href="/node/{{ doc.id }}/delete" class="event-card__action event-card__action--delete">{{ 'Delete'|t }}</a>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <div class="member-notice">
        <p>{{ 'No historical documents have been approved yet. Be the first to submit one!'|t }}</p>
      </div>
    {% endif %}
  </section>

</div>
