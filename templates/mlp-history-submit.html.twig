{#
/**
 * @file mlp-history-submit.html.twig
 * Meadow Lane Park — history document submission form.
 */
#}
<div class="history-submit">
  <div class="history-submit__back">
    <a href="/history" class="member-announcement-detail__back-link">← {{ 'Back to History'|t }}</a>
  </div>
  <div class="history-submit__card">
    <h2 class="history-submit__title">{{ 'Submit a Historical Document'|t }}</h2>
    <p class="history-submit__intro">{{ 'Share a piece of Meadow Lane history. Submissions will be reviewed before appearing on the History page.'|t }}</p>
    {{ form }}
  </div>
</div>
