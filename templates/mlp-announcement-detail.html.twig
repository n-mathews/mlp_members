{#
/**
 * @file mlp-announcement-detail.html.twig
 * Meadow Lane Park — single announcement detail page.
 */
#}
<div class="member-announcement-detail">

  <div class="member-announcement-detail__back">
    <a href="/announcements" class="member-announcement-detail__back-link">
      ← {{ 'All announcements'|t }}
    </a>
    {% if can_edit or can_delete %}
      <div class="member-announcement-detail__actions">
        {% if can_edit %}
          <a href="/node/{{ node_id }}/edit" class="event-card__action event-card__action--edit">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
              <path d="M11.5 2.5l2 2L5 13H3v-2L11.5 2.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            </svg>
            {{ 'Edit'|t }}
          </a>
        {% endif %}
        {% if can_delete %}
          <a href="/node/{{ node_id }}/delete" class="event-card__action event-card__action--delete">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
              <path d="M3 4h10M6 4V3h4v1M5 4v8h6V4H5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ 'Delete'|t }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <article class="member-announcement-detail__article">

    <header class="member-announcement-detail__header">
      <div class="member-announcement-detail__badges">
        {% if sticky %}
          <span class="member-announcement-card__pin">
            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
              <path d="M9.5 1a1 1 0 011 1v1.5h1a1 1 0 010 2H11v5l1 2H4l1-2V5.5H4a1 1 0 010-2h1V2a1 1 0 011-1h3.5z"/>
            </svg>
            {{ 'Pinned'|t }}
          </span>
        {% endif %}
        {% if featured %}
          <span class="member-announcement-card__badge">{{ 'Featured'|t }}</span>
        {% endif %}
      </div>

      <h2 class="member-announcement-detail__title">{{ title }}</h2>

      {% if categories %}
        <div class="member-announcement-detail__cats">
          {% for cat in categories %}
            <a href="/announcements?category={{ cat.id }}" class="member-announcement-card__cat">{{ cat.name }}</a>
          {% endfor %}
        </div>
      {% endif %}

      <time class="member-announcement-detail__date" datetime="{{ created|format_date('html_datetime') }}">
        {{ created|format_date('long') }}
      </time>
    </header>

    {% if body %}
      <div class="member-announcement-detail__body prose">
        {{ body|raw }}
      </div>
    {% endif %}

    {# DEBUG: attachments count = {{ attachments|length }} #}
    {% if attachments %}
      <div class="member-announcement-detail__attachments">
        <h4 class="member-announcement-detail__attachments-title">{{ 'Attachments'|t }}</h4>
        <ul class="member-doc-list">
          {% for file in attachments %}
            <li class="member-doc-item">
              <a href="{{ file.url }}" class="member-doc-item__link" target="_blank" rel="noopener noreferrer">
                <span class="member-doc-item__icon" aria-hidden="true">
                  {% if 'pdf' in file.mime %}
                    <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  {% elseif 'image' in file.mime %}
                    <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% endif %}
                </span>
                <span class="member-doc-item__name">{{ file.description ?: file.name }}</span>
                <span class="member-doc-item__meta">{{ file.size }}</span>
                <svg class="member-doc-item__arrow" viewBox="0 0 16 16" fill="none" width="12" height="12" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

  </article>

</div>
