{#
/**
 * @file mlp-announcement-detail.html.twig
 * Meadow Lane Park — single announcement detail page.
 */
#}
<div class="member-announcement-detail">

  <div class="member-announcement-detail__back">
    <a href="/announcements" class="member-announcement-detail__back-link">
      ← {{ 'All announcements'|t }}
    </a>
  </div>

  <article class="member-announcement-detail__article">

    <header class="member-announcement-detail__header">
      <div class="member-announcement-detail__badges">
        {% if sticky %}
          <span class="member-announcement-card__pin">
            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
              <path d="M9.5 1a1 1 0 011 1v1.5h1a1 1 0 010 2H11v5l1 2H4l1-2V5.5H4a1 1 0 010-2h1V2a1 1 0 011-1h3.5z"/>
            </svg>
            {{ 'Pinned'|t }}
          </span>
        {% endif %}
        {% if featured %}
          <span class="member-announcement-card__badge">{{ 'Featured'|t }}</span>
        {% endif %}
      </div>

      <h2 class="member-announcement-detail__title">{{ title }}</h2>

      {% if categories %}
        <div class="member-announcement-detail__cats">
          {% for cat in categories %}
            <a href="/announcements?category={{ cat.id }}" class="member-announcement-card__cat">{{ cat.name }}</a>
          {% endfor %}
        </div>
      {% endif %}

      <time class="member-announcement-detail__date" datetime="{{ created|format_date('html_datetime') }}">
        {{ created|format_date('long') }}
      </time>
    </header>

    {% if body %}
      <div class="member-announcement-detail__body prose">
        {{ body|raw }}
      </div>
    {% endif %}

  </article>

</div>
