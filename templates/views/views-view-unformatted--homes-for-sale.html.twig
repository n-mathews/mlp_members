{#
/**
 * @file views-view-unformatted--homes-for-sale.html.twig
 * Meadow Lane Park — row wrapper for the homes_for_sale View.
 * Renders the listings-grid <div> and each node teaser inside it.
 */
#}
<div{{ attributes.addClass('listings-grid') }}>
  {% for row in rows %}
    <div{{ row.attributes.addClass('listing-card-wrapper') }}>
      {{- row.content -}}
    </div>
  {% endfor %}
</div>
